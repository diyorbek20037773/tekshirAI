# === Database ===
DATABASE_URL=postgresql+asyncpg://tekshirai:password@localhost:5432/tekshirai
DATABASE_URL_SYNC=postgresql://tekshirai:password@localhost:5432/tekshirai

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# === Gemini API Keys (FREE — Google AI Studio dan oling) ===
# Har bir Gmail akkountdan 1 ta kalit: https://aistudio.google.com/apikey
GEMINI_API_KEYS=AIzaSy_key1,AIzaSy_key2,AIzaSy_key3
GEMINI_MODEL=gemini-2.5-flash

# === App Settings ===
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=your-secret-key-for-jwt-change-this
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# === Limits ===
FREE_DAILY_LIMIT=3
PREMIUM_DAILY_LIMIT=999
MAX_IMAGE_SIZE_MB=10
FREE_CHAT_LIMIT=3
PREMIUM_CHAT_LIMIT=10
